cc_library_shared {
    name: "vendor.example.hellohidl@1.0-impl",
    proprietary: true,
    relative_install_path: "hw",
    srcs: [
        "Hello.cpp",
    ],
    shared_libs: [
        "libhidlbase",
        "liblog",
        "libutils",
        "vendor.example.hellohidl@1.0",
    ],
    export_include_dirs: ["."],
    cflags: [
        "-Wall",
        "-Werror",
    ],
}

cc_binary {
    name: "vendor.example.hellohidl@1.0-service",
    proprietary: true,
    relative_install_path: "hw",
    srcs: [
        "service.cpp",
    ],
    shared_libs: [
        "libhidlbase",
        "liblog",
        "libutils",
        "vendor.example.hellohidl@1.0",
        "vendor.example.hellohidl@1.0-impl",
    ],
    init_rc: [
        "vendor.example.hellohidl@1.0-service.rc",
    ],
    vintf_fragments: [
        "vendor.example.hellohidl@1.0-service.xml",
    ],
    cflags: [
        "-Wall",
        "-Werror",
    ],
}
