    name: "vendor_example_hardware_interfaces_license",
    visibility: [":__subpackages__"],
    license_kinds: [
        "SPDX-license-identifier-Apache-2.0",
    ],
    license_text: [
        "NOTICE",
    ],
}

hidl_package_root {
    name: "vendor.example",
    path: "vendor/example/hardware/interfaces",
}
